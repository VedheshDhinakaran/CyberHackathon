String.prototype.startsWith=function(b){var a=this.match(b+"$");return!a?!1:a[0]===b};String.prototype.endsWith=function(b){var a=b;"*"==a&&(a="\\*");a=this.match(a+"$");return!a?!1:a[0]===b};String.prototype.trimEnd=function(b){for(var a=this;a.endsWith(b);)a=a.substring(0,a.length-1);return a};readCookie=function(b){return $.cookie(b)};writeCookie=function(b,a){allowCookie(b)&&$.cookie(b,a)};
allowCookie=function(b){var a=!0;if("false"==AllowCookies)a=!1;else if("true"==AllowCookies)a=!0;else{var a=!1,d=AllowedCookies.split("|");$.each(d,function(d,c){if(c.endsWith("*")){var e=c.trimEnd("*");b.startsWith(e)&&(a=!0)}else c===b&&(a=!0)})}return a};

